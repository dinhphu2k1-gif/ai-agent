# Copy to .env and fill in values. Do not commit .env.

# --- Chat HTTP API (Phase 0+) ---
API_HOST=0.0.0.0
API_PORT=8080
API_CORS_ORIGINS=http://localhost:5173
CHAT_REQUIRE_AUTH=false
CHAT_JWT_SECRET=change-me-in-production
CHAT_JWT_ALGORITHM=HS256

# --- Chat production hardening (Phase 4) ---
CHAT_RUN_TIMEOUT_SEC=60
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_SEC=60
CHAT_ENFORCE_CHANNEL_ACL=true
# SENTRY_DSN=

# --- Chat persistence (Phase 3) ---
# Create DB: createdb agentic_chat  (or use existing my_database)
# psql "$CHAT_DATABASE_URL" -f scripts/migrations/chat/001_init.sql
# psql "$CHAT_DATABASE_URL" -f scripts/migrations/chat/002_channel_members.sql
# psql "$CHAT_DATABASE_URL" -f scripts/migrations/chat/003_attachments.sql
CHAT_DATABASE_URL=postgresql://admin:password123@localhost:5432/agentic_chat
CHAT_USE_MEMORY=false
CHAT_PERSIST_SSE_EVENTS=true
CHAT_ATTACHMENT_STORAGE_PATH=./data/chat_attachments
CHAT_RUN_EVENTS_RETENTION_DAYS=7
# false = Telegram-like (trace steps + final paragraphs only; no planner JSON tokens)
CHAT_EMIT_CONTENT_DELTA=false
# LangGraph checkpoint — requires Redis Stack (RediSearch), not plain redis:alpine
# docker compose up -d redis   (image: redis/redis-stack-server)
REDIS_URL=redis://localhost:6379/0

# --- OpenSearch (metadata agent) — docker compose up -d opensearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=MetadaaAgent@2026!
OPENSEARCH_INDEX=data_dictionary
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

