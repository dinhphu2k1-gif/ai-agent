# Copy to .env — do not commit real secrets
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/filter_db
REDIS_URL=redis://localhost:6379/0
IAM_BASE_URL=https://iam.example.com
IAM_TOKEN_VALIDATE_PATH=/v1/token/validate
IAM_TIMEOUT_SECONDS=2.5
IAM_MAX_RETRIES=2
# IAM_CIRCUIT_BREAKER_ENABLED=false
USER_CONTEXT_TTL_SECONDS=600
# redis | memory (memory for local/tests without Redis)
USER_CONTEXT_CACHE_BACKEND=redis
PERMISSION_SNAPSHOT_TTL_SECONDS=180
RUNTIME_POSTGRES_URL=
# Runtime SELECT DB for /api/v1/sql/execute and /filter (when RUNTIME_POSTGRES_URL unset).
# Permission catalog/admin API still use DATABASE_URL above.
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=admin
# PG_PASSWORD=change-me
# PG_DATABASE=my_database
RUNTIME_QUERY_TIMEOUT_SECONDS=30
# If unset, OpenSearch integration tests probe http://127.0.0.1:9201 (docker compose)
# FILTER_INTEGRATION_OPENSEARCH_URL=http://127.0.0.1:9201
# OpenSearch: set OPENSEARCH_BASE_URL *or* HOST+PORT (+ USER/PASSWORD for secured clusters).
# Docker compose maps host 9201 -> container 9200: use OPENSEARCH_BASE_URL=http://127.0.0.1:9201
# OPENSEARCH_BASE_URL=
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
# Secured local OpenSearch (curl --insecure): USE_SSL=true, VERIFY_CERTS=false
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change-me
OPENSEARCH_INDEX=data_dictionary
OPENSEARCH_TIMEOUT_SECONDS=30
MASKING_HASH_SALT=dev-masking-salt-change-in-prod
# Optional: disposable Postgres URL for pytest integration (see README).
# If unset, tests probe docker-compose default: filter@127.0.0.1:5433/filter_db
# FILTER_INTEGRATION_DATABASE_URL=postgresql+psycopg://filter:filter@127.0.0.1:5433/filter_db
# Optional: require X-Admin-Token on /v1/admin/* (MVP guard; leave unset for dev-only)
# ADMIN_API_TOKEN=
# Local FE integration: skip IAM; any non-empty Bearer token maps to demo user (run seed first)
# AUTH_BYPASS_ENABLED=true
# AUTH_BYPASS_USER_ID=aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa
# AUTH_BYPASS_USERNAME=demo_user
# AUTH_BYPASS_EMAIL=demo@local.dev
# Browser FE (comma-separated origins). Add your dev server URL if not listed.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
